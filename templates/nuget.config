<?xml version="1.0" encoding="utf-8"?>
<!-- Optional repo-root config for deterministic nuget.org-only restores.
     B44.Common and B44.Standards are public packages; no credentials or
     private package source are required. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
