<?xml version="1.0" encoding="utf-8"?>
<!-- Repo-root nuget.config for B44 game repos consuming B44.Common.
     NO CREDENTIALS IN THIS FILE — it is committed. Local dev supplies a PAT
     into the user-level config once:
       dotnet nuget update source b44 --username DA-Sandman-Jr \
         --password YOUR_CLASSIC_PAT_WITH_read:packages --store-password-in-clear-text
     CI supplies it via the B44_PACKAGES_PAT secret (see build-test.yml). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="b44" value="https://nuget.pkg.github.com/DA-Sandman-Jr/index.json" />
  </packageSources>
</configuration>
