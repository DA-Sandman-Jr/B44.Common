# B44 studio analyzer severities. Canonical copy lives in B44.Common/B44.Standards;
# distributed via the B44.Standards package (global analyzer config, applies to
# every referencing project). Style/whitespace live in each repo's .editorconfig.
is_global = true
global_level = 100

# ── Code metrics (thresholds in CodeMetricsConfig.txt) ─────────────────────
# CA1502 cyclomatic complexity — disabled by default in the SDK; we enable it.
# Deliberately stricter than the SDK default (25): agents are prone to growing
# coordinators and nested branching. Guardrail, not proof of bad design.
dotnet_diagnostic.CA1502.severity = warning

# ── Banned APIs (RS0030 fires from BannedSymbols lists) ────────────────────
dotnet_diagnostic.RS0030.severity = error

# ── Godot-repo accommodation ───────────────────────────────────────────────
# Godot repos must set GenerateAssemblyInfo=false (the export pipeline emits
# its own attributes), which makes CA1016 (assembly version) unsatisfiable.
# Package projects satisfy it via <Version> regardless.
dotnet_diagnostic.CA1016.severity = none

# ── Meziantou curated allowlist (MeziantouAnalysisMode=None turns the rest
#    off; these opt back in). Defect-focused; style and speculative-perf
#    rules deliberately excluded. Validate empirically before promoting any
#    of these to error alongside TreatWarningsAsErrors. ─────────────────────
# Strings and input correctness
dotnet_diagnostic.MA0001.severity = warning
dotnet_diagnostic.MA0002.severity = warning
dotnet_diagnostic.MA0009.severity = warning
dotnet_diagnostic.MA0015.severity = warning
# Definite correctness problems
dotnet_diagnostic.MA0022.severity = warning
dotnet_diagnostic.MA0060.severity = warning
dotnet_diagnostic.MA0064.severity = warning
dotnet_diagnostic.MA0072.severity = warning
dotnet_diagnostic.MA0085.severity = warning
dotnet_diagnostic.MA0100.severity = warning
dotnet_diagnostic.MA0172.severity = warning
dotnet_diagnostic.MA0195.severity = warning
# Async hazards
dotnet_diagnostic.MA0035.severity = warning
dotnet_diagnostic.MA0042.severity = warning
dotnet_diagnostic.MA0134.severity = warning
dotnet_diagnostic.MA0147.severity = warning
dotnet_diagnostic.MA0155.severity = warning
# Forward an in-scope CancellationToken (added for the HTTP-client repos,
# where CT plumbing is heavy and forwarding gaps are the classic bug;
# near-zero noise in the games, which have no tokens in scope).
dotnet_diagnostic.MA0040.severity = warning
# Structure: method length (60 lines / 40 statements, configured below).
# MA0048 (one type per file) intentionally NOT enabled — cohesive multi-type
# files (StructuredGameLogger.cs, catalogs) are sanctioned B44 style.
dotnet_diagnostic.MA0051.severity = warning
MA0051.maximum_lines_per_method = 60
MA0051.maximum_statements_per_method = 40
